NODE_ENV=production
PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/supportvision?retryWrites=true&w=majority

# CORS — comma-separated origins
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Mediasoup
MEDIASOUP_WORKERS=2
MEDIASOUP_LOG_LEVEL=warn
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100

# IMPORTANT: Set to the public IP of your media server (Railway/Fly.io assigns this)
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=YOUR_PUBLIC_IP_HERE

# FFmpeg
FFMPEG_PATH=ffmpeg
RECORDINGS_DIR=/tmp/recordings
